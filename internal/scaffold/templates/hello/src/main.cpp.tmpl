#include <mitiru/Mitiru.hpp>

#ifndef {{.ScenarioUrlMacro}}
#define {{.ScenarioUrlMacro}} ""
#endif

namespace {

class {{.GameClassName}} final : public mitiru::Game {
public:
    void update(float /*dt*/) override {}

    void draw(mitiru::Screen& screen) override {
        const float w = static_cast<float>(screen.width());
        const float h = static_cast<float>(screen.height());
        screen.drawRect(
            sgc::Rectf{0.0f, 0.0f, w, h},
            sgc::Colorf{0.04f, 0.05f, 0.10f, 1.0f});
    }

    [[nodiscard]] mitiru::Size layout(int outsideW, int outsideH) override {
        return {outsideW, outsideH};
    }
};

}  // namespace

int main(int /*argc*/, char** /*argv*/) {
    mitiru::Engine engine;
    {{.GameClassName}} game;

    mitiru::EngineConfig cfg;
    cfg.title = "{{.ProjectName}}";
    cfg.windowWidth = 1280;
    cfg.windowHeight = 720;
    cfg.vsync = true;
    cfg.skipDefaultFont = true;
    cfg.cefStartUrl = {{.ScenarioUrlMacro}};

    engine.run(game, cfg);
    return 0;
}
