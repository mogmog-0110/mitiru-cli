// {{.ProjectName}} — game-as-DLL entry point (v0.2.0 / ADR 0005)
//
// Everything persistent lives in GameMemory. The host owns the pointer, so
// state survives DLL hot-reloads when you launch with `mitiru watch` (or
// directly with `mitiru_host --watch <dll>`).
//
// Communication is C-only signal flow (ADR 0005):
//   host → DLL: InputSnapshot   keys / mouse / CEF action events
//   DLL → host: FrameIntents    state pushes / quit / screenshot / palette
//
// The host calls mitiru_module_load() once on launch and once again on every
// reload. *memory is preserved across reloads — only the function pointers
// (and code) change.

#include <mitiru/core/Screen.hpp>
#include <mitiru/module/ModuleApi.hpp>

namespace {{.ProjectIdent}}
{

namespace vk
{
constexpr int Escape = 0x1B;
constexpr int Left   = 0x25;
constexpr int Up     = 0x26;
constexpr int Right  = 0x27;
constexpr int Down   = 0x28;
}  // namespace vk

struct GameMemory
{
    float t       = 0.0f;
    float playerX = 640.0f;
    float playerY = 360.0f;
};

void on_init(void* /*memory*/) {}

void on_update(void* memory, float dt,
               const mitiru::module::InputSnapshot* input,
               mitiru::module::FrameIntents* intents)
{
    if (memory == nullptr || input == nullptr || intents == nullptr) { return; }
    auto& mem = *static_cast<GameMemory*>(memory);

    mem.t += dt;

    if (input->keysJustPressed[vk::Escape]) { intents->requestStop = 1; }

    constexpr float kSpeed = 320.0f;
    if (input->keysDown[vk::Left])  { mem.playerX -= kSpeed * dt; }
    if (input->keysDown[vk::Right]) { mem.playerX += kSpeed * dt; }
    if (input->keysDown[vk::Up])    { mem.playerY -= kSpeed * dt; }
    if (input->keysDown[vk::Down])  { mem.playerY += kSpeed * dt; }
}

void on_draw(void* memory, mitiru::Screen* screen)
{
    if (memory == nullptr || screen == nullptr) { return; }
    auto& mem = *static_cast<GameMemory*>(memory);

    screen->clear(sgc::Colorf{0.06f, 0.07f, 0.12f, 1.0f});

    constexpr float kSize = 32.0f;
    screen->drawRect(
        sgc::Rectf{mem.playerX - kSize * 0.5f,
                   mem.playerY - kSize * 0.5f,
                   kSize, kSize},
        sgc::Colorf{0.45f, 0.85f, 0.95f, 1.0f});
}

void on_shutdown(void* /*memory*/) {}

}  // namespace {{.ProjectIdent}}

extern "C"
{

#if defined(_WIN32)
#define {{.UpperIdent}}_DLL_EXPORT __declspec(dllexport)
#else
#define {{.UpperIdent}}_DLL_EXPORT __attribute__((visibility("default")))
#endif

{{.UpperIdent}}_DLL_EXPORT
void mitiru_module_load(mitiru::module::ModuleApi* api, void** memory)
{
    if (api == nullptr || memory == nullptr) { return; }

    // First-time load: allocate persistent state. On hot reload the host
    // hands us back the same pointer so gameplay survives the code swap.
    if (*memory == nullptr)
    {
        *memory = new {{.ProjectIdent}}::GameMemory{};
    }

    api->version     = mitiru::module::kCurrentApiVersion;
    api->on_init     = &{{.ProjectIdent}}::on_init;
    api->on_update   = &{{.ProjectIdent}}::on_update;
    api->on_draw     = &{{.ProjectIdent}}::on_draw;
    api->on_shutdown = &{{.ProjectIdent}}::on_shutdown;
}

{{.UpperIdent}}_DLL_EXPORT
void mitiru_module_unload(void* /*memory*/) {}

}  // extern "C"
