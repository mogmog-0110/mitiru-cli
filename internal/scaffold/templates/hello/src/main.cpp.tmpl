// {{.ProjectName}} — ゲームは「状態の struct + update + draw」だけ。
// 状態 (メンバ変数) は flat POD なら、ホットリロード・巻き戻し・リプレイが
// 何もしなくても全部乗る (mitiru watch で kSpeed を書き換えて保存してみて)。

#include <mitiru/module/Game.hpp>
using namespace mitiru;

struct {{.ProjectIdent}}Game
{
    float x = 640.0f;
    float y = 360.0f;

    void update(Input in, Hud hud, float dt)
    {
        constexpr float kSpeed = 320.0f;   // ★ watch 中にここを変えて保存
        Stick m = in.move();               // 矢印 + WASD + 十字キー + 左スティック統合
        x += m.x * kSpeed * dt;
        y += m.y * kSpeed * dt;
        if (in.cancelPressed()) { hud.quit(); }
        hud.set("hud.x", (int)x);          // assets/scene.html の data-m-text="hud.x" へ
        hud.set("hud.y", (int)y);
    }

    void draw(Screen& s)
    {
        s.fillScreen(hex(0x14182A));
        s.fillCircle(x, y, 24.0f, color::Cyan);
    }
};

MITIRU_GAME({{.ProjectIdent}}Game)
