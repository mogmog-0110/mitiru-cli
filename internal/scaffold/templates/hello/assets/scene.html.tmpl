<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<title>{{.ProjectName}}</title>
<style>
  /* The HUD is a TRANSPARENT overlay composited on top of your C++ drawing.
     Keep the background transparent so whatever you draw in on_draw() (the
     native render layer) shows through. Put your HUD elements (score, timers,
     menus) here in HTML/CSS; drive them from C++ via FrameIntents state pushes
     + window.mitiru.onStateChange(...). See examples/hello_game for the full
     bridge wiring. */
  html, body {
    margin: 0;
    height: 100%;
    overflow: hidden;
    background: transparent;          /* ← lets the C++ render layer show */
    pointer-events: none;             /* clicks fall through to the game */
    font-family: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", system-ui, sans-serif;
    color: #fff;
  }
  /* Discreet corner watermark — replace with your real HUD. */
  .hint {
    position: absolute;
    left: 12px;
    bottom: 10px;
    font-size: 12px;
    opacity: 0.55;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }
</style>
</head>
<body>
  <div class="hint">{{.ProjectName}} · edit assets/scene.html for your HUD</div>

  <!-- This default scene is pure CSS — no JS bridge required.
       To subscribe to C++ state from JS, see examples/hello_game in the
       engine repo: it shows how to wire a StateStore / onStateChange bridge
       with `mitiru_runtime/mitiru_cef_state.js`. -->
</body>
</html>
