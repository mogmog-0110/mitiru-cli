// {{.ProjectName}} — クリックで数を稼ぐ最小ゲーム。
// ロジックは C++ (このファイル)、表示は HTML/CSS (assets/scene.html)。JS は書かない。

#include <mitiru/module/Game.hpp>
using namespace mitiru;

struct {{.ProjectIdent}}Game
{
    int count = 0;

    void update(Input in, Hud hud, float /*dt*/)
    {
        if (in.mousePressed()) { ++count; }   // 左クリックした瞬間だけ
        if (in.cancelPressed()) { hud.quit(); }
        hud.set("hud.count", count);          // assets/scene.html の data-m-text="hud.count" へ
    }

    void draw(Screen& s)
    {
        s.fillScreen(hex(0x14182A));
        s.fillCircle(640.0f, 360.0f, 24.0f + (float)count, color::Yellow);   // 押すほど育つ
    }
};

MITIRU_GAME({{.ProjectIdent}}Game)
