[project]
name = "{{.ProjectName}}"
version = "0.1.0"
engine = "{{.EngineVersion}}"

[window]
title = "{{.ProjectName}}"
width = 1280
height = 720
vsync = true

[cef]
# The host derives the scene URL from the DLL path
# (default: file:///./<project>/assets/scene.html).
# Set start_url here to override.
skip_default_font = true

[font]
# native draw 用フォントアトラス: none|latin|kana|japanese
# 既定 none = フォント skip（起動高速。HTML/CEF UI の日本語はそのまま出る）。
# native の drawTextInRect 等で日本語を描くなら "japanese" にする。
atlas = "none"

[build]
backend = "auto"

[lofi]
# ローファイ・ポストFX (DX12): 低解像描画 + パレット量子化 + 4×4 Bayer ディザ。
# DirectX5 / 256色・16bit 期の網点質感を再現する。既定 OFF。
# enabled = true       # マスタースイッチ
# width = 320          # 内部解像度（例 320x240 / 640x480）
# height = 240
# bits = "5,6,5"       # 量子化ビット数 R,G,B（"5,6,5"=RGB565 / "3,3,2"=256色相当）
# dither = 1.0         # ディザ強度（0=無し）
enabled = false
